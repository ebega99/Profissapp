# Profissapp API - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ============================================
# AMBIENTE
# ============================================
APP_ENV=production
APP_DEBUG=false

# ============================================
# MERCADO PAGO
# ============================================
# Obter em: https://www.mercadopago.com.br/developers/panel
MERCADO_PAGO_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
MERCADO_PAGO_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# ============================================
# SEGURANÇA
# ============================================
SECRET_KEY=change_me_with_a_very_secure_random_string_32_characters_minimum

# ============================================
# URLs
# ============================================
APP_URL=https://profissapp.fibra99.com
FRONTEND_URL=https://profissapp.fibra99.com
